# 日志（tracing EnvFilter 表达式，如 info / info,sqlx=warn）。两个进程共用。
RUST_LOG=info

# ====== panel-server ======
PANEL_BIND_ADDR=0.0.0.0:8080
PANEL_DATABASE_URL=sqlite://./data/emorelay.db
PANEL_JWT_SECRET=change-me-to-a-long-random-secret
PANEL_JWT_EXPIRY_HOURS=24
PANEL_CORS_ORIGIN=http://localhost:5173

# 首次启动种子 admin：若库内尚无 admin 用户，则用以下值创建。
# 已有 admin 则忽略；密码必须显式设置，留空会启动失败。
PANEL_BOOTSTRAP_ADMIN_USERNAME=admin
PANEL_BOOTSTRAP_ADMIN_PASSWORD=

# gRPC 控制面（panel-server 监听，node-agent 连入）
PANEL_GRPC_BIND_ADDR=0.0.0.0:50051

# P3a 起 gRPC 控制面默认强制 mTLS,证书由内置 CA(${PANEL_DATA_DIR}/tls/)自动签发。
# 开发逃生阀:置 1 退回 plaintext(Agent 端 AGENT_CONTROL_ENDPOINT 用 http:// 配合)。
PANEL_DEV_DISABLE_MTLS=0
# 内置 CA 给 server 证书写入的对外主机名(Agent 连入校验)。留空 → 仅 127.0.0.1/localhost。
PANEL_PUBLIC_HOST=

# P3a 起已弃用:gRPC TLS 走内置 CA,以下三项被忽略(保留仅为兼容旧 .env)
# gRPC TLS（可选；两个都为空 → plaintext 仅供 dev）。生产强烈建议配。
# 用 `sh scripts/gen-dev-tls.sh ./tls` 生成自签证书 + 客户端证书。
PANEL_GRPC_TLS_CERT=
PANEL_GRPC_TLS_KEY=

# 可选 mTLS：从此 PEM 加载根 CA 校验 Agent 客户端证书。
# 留空 → 仅 server-side TLS（Agent 验 server，不验 Agent）。
# 启用要求：PANEL_GRPC_TLS_CERT/KEY 已配置，且 Agent 端配 AGENT_GRPC_CLIENT_CERT/KEY。
PANEL_GRPC_TLS_CLIENT_CA=

# 用户级 sweeper:到期扫描间隔(默认 60s)与滚动 30 天流量配额扫描间隔(默认 300s)。
# 到期/超额用户名下全部规则自动停用,并记录聚合 audit。下限 5 秒(代码强制 .max(5))。
PANEL_USER_EXPIRY_SWEEP_SECS=60
PANEL_USER_QUOTA_SWEEP_SECS=300

# ====== node-agent ======
AGENT_NODE_ID=
# https:// 开头自动启用 TLS；http:// 走 plaintext。
AGENT_CONTROL_ENDPOINT=http://127.0.0.1:50051
AGENT_TOKEN=
AGENT_STATE_PATH=./agent-state.json

# 信任的 CA PEM 路径（验证 panel-server 证书）。留空走系统根证书（生产 + 真证书时用）。
AGENT_GRPC_CA_CERT=

# mTLS 客户端证书 + 私钥（PEM）。Server 端 PANEL_GRPC_TLS_CLIENT_CA 启用时必填,
# 两者必须同时给或同时空。
AGENT_GRPC_CLIENT_CERT=
AGENT_GRPC_CLIENT_KEY=

# node-agent 统计上报间隔（秒）。默认 60。
# 加大 → 控制面写库负载下降，时序粒度变粗；缩小 → 更密但写更频繁。
AGENT_STATS_INTERVAL_SECS=60

# panel-server 数据目录(SQLite 文件 + agent 二进制 + 后续 TLS 材料)。
PANEL_DATA_DIR=/var/lib/emorelay
# 面板对外可访问的 base URL,用于生成节点安装命令的下载基址。
# 例:https://relay.example.com  留空 → 节点详情隐藏「复制安装命令」按钮。
PANEL_PUBLIC_BASE_URL=
